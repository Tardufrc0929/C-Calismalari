                {"TDT: ", 12, 1}, // TDT
                {"Almanca: ", 13, 2}, // Almanca
                
            };
            double ortalama = 0;

            for (int i = 0; i < 13; i++)
            {
                

                Console.WriteLine(dersler[i, 0]);
