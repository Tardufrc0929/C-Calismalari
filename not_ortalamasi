{
    internal class Program
    {
        static void Main(string[] args)
        {
            object[,] dersler = new object[,]
            {
                {"Matematik: ", 1, 6}, // Matematik
                {"Fizik: ", 2, 2}, // Fizik
                {"Kimya: ", 3, 2}, // Kimya
                {"Biyoloji: ", 4, 2}, // Biyoloji
                {"Türk Dili ve Edebiyatı: ", 5, 5}, // Türk Dili ve Edebiyatı
                {"İngilizce: ", 6, 4}, // İngilizce
